# ── InovaFarma (Web API local — executável inovafarma-api) ──────────────
# Endereço da API na máquina/rede da farmácia. Contra o mock: http://localhost:9800
INOVAFARMA_URL="http://localhost:9800"
# Credenciais geradas no credenciamento do Portal PS (Precisão Sistemas).
# Contra o mock, qualquer valor não-vazio funciona.
INOVAFARMA_CLIENT_ID=""
INOVAFARMA_CLIENT_SECRET=""
INOVAFARMA_LOJA_ID=""

# ── FarmaVida (nuvem) ────────────────────────────────────────────────────
# URL pública do site (produção: https://teste-web-vendas.vercel.app)
FARMAVIDA_URL="http://localhost:3000"
# Token da UNIDADE, gerado em Admin → Integração (aparece uma única vez).
FARMAVIDA_TOKEN=""

# ── Cadências (opcional) ─────────────────────────────────────────────────
# SYNC_CATALOGO_MIN="5"
# POLL_PEDIDOS_SEG="30"

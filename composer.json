{
  "name": "farmavida/platform",
  "description": "FarmaVida - sistema completo para farmacia online, operacao, estoque, pagamentos, receitas e integracoes.",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "ext-curl": "*",
    "ext-pdo": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "phpmailer/phpmailer": "^6.9",
    "mercadopago/dx-php": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    },
    "files": [
      "app/Helpers/functions.php"
    ]
  },
  "scripts": {
    "migrate": "php scripts/migrate.php",
    "seed": "php scripts/seed.php",
    "lint": "php scripts/lint_php.php",
    "readiness": "php market_readiness_checks.php"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {}
  }
}

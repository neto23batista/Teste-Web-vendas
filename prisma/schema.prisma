// FarmaVida Next — Prisma schema (PostgreSQL / Neon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Conexão da aplicação: usa o pooler do Neon (pgbouncer).
  url       = env("DATABASE_URL")
  // Conexão direta (sem pooler) — usada pelo Prisma só nas migrations.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ─────────────────────────── Enums ───────────────────────────
enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  SHIPPED
  DELIVERED
  CANCELED
}

enum PaymentProvider {
  MERCADO_PAGO
  PIX
  CASH
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

enum PrescriptionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CouponType {
  PERCENT
  FIXED
}

enum PharmacyType {
  MATRIZ
  FILIAL
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELED
}

// ─────────────────────────── Usuário ───────────────────────────
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(CUSTOMER)
  cpf          String?
  phone        String?
  // Unidade à qual um admin pertence. Null em clientes. Admin cuja unidade é
  // MATRIZ tem escopo "global" (vê/gere todas as unidades).
  pharmacyId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  prescriptions Prescription[]
  loyalty       LoyaltyAccount?
  carts         Cart[]
  resetTokens   PasswordResetToken[]
  favorites     Favorite[]
  auditLogs     AuditLog[]
  subscriptions Subscription[]
  pharmacy      Pharmacy? @relation(fields: [pharmacyId], references: [id])

  @@index([role])
  @@index([pharmacyId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  label      String   @default("Casa")
  recipient  String
  zip        String
  street     String
  number     String
  complement String?
  district   String
  city       String
  state      String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
}

// ─────────────────────────── Catálogo ───────────────────────────
model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  icon     String?
  emoji    String?
  sort     Int       @default(0)
  products Product[]
}

model Brand {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  products Product[]
}

model Product {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  description          String   @db.Text
  shortDescription     String?  @db.Text
  emoji                String?
  sku                  String?  @unique
  ean                  String?
  price                Float
  promoPrice           Float?
  requiresPrescription Boolean  @default(false)
  isGeneric            Boolean  @default(false)
  activeIngredient     String?
  rating               Float    @default(0)
  ratingCount          Int      @default(0)
  active               Boolean  @default(true)
  featured             Boolean  @default(false)
  categoryId           String
  brandId              String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  category  Category       @relation(fields: [categoryId], references: [id])
  brand     Brand?         @relation(fields: [brandId], references: [id])
  images    ProductImage[]
  cartItems CartItem[]
  orderItems OrderItem[]
  reviews   Review[]
  favoritedBy Favorite[]
  inventory Inventory[]
  subscriptions Subscription[]

  @@index([categoryId])
  @@index([brandId])
  @@index([active, featured])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String  @db.Text
  alt       String?
  sort      Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ─────────────────────────── Carrinho ───────────────────────────
model Cart {
  id           String   @id @default(cuid())
  userId       String?
  sessionToken String?  @unique
  // Unidade que o cliente está comprando (estoque é por unidade). Null = ainda
  // não escolheu; a leitura usa a unidade padrão (matriz) como fallback.
  pharmacyId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  pharmacy Pharmacy?  @relation(fields: [pharmacyId], references: [id], onDelete: SetNull)
  items    CartItem[]

  @@index([userId])
  @@index([pharmacyId])
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  productId String
  qty       Int    @default(1)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([productId])
}

// ─────────────────────────── Pedidos ───────────────────────────
model Order {
  id            String      @id @default(cuid())
  number        String      @unique
  userId        String
  status        OrderStatus @default(PENDING)
  requiresPrescription Boolean @default(false)
  subtotal      Float
  discount      Float       @default(0)
  shipping      Float       @default(0)
  total         Float
  paymentMethod String?
  couponCode    String?
  addressId     String?
  // Unidade que atende o pedido (roteada por CEP, matriz como fallback).
  // Nullable só por compatibilidade com a migração; sempre populada na criação.
  pharmacyId    String?
  notes         String?     @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user          User                 @relation(fields: [userId], references: [id])
  address       Address?             @relation(fields: [addressId], references: [id])
  pharmacy      Pharmacy?            @relation(fields: [pharmacyId], references: [id])
  items         OrderItem[]
  payment       Payment?
  prescriptions Prescription[]
  loyaltyTx     LoyaltyTransaction[]

  @@index([userId])
  @@index([status])
  @@index([pharmacyId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String?
  name      String
  price     Float
  qty       Int

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model Payment {
  id         String          @id @default(cuid())
  orderId    String          @unique
  provider   PaymentProvider @default(MERCADO_PAGO)
  status     PaymentStatus   @default(PENDING)
  externalId String?
  amount     Float
  raw        Json?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ─────────────────────────── Receitas ───────────────────────────
model Prescription {
  id        String             @id @default(cuid())
  userId    String
  orderId   String?
  fileUrl   String             @db.Text
  status    PrescriptionStatus @default(PENDING)
  createdAt DateTime           @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId])
}

// ─────────────────────────── Fidelidade ───────────────────────────
model LoyaltyAccount {
  id           String               @id @default(cuid())
  userId       String               @unique
  points       Int                  @default(0)
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions LoyaltyTransaction[]
}

model LoyaltyTransaction {
  id        String   @id @default(cuid())
  accountId String
  points    Int
  reason    String
  orderId   String?
  createdAt DateTime @default(now())

  account LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  order   Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([accountId])
}

// ─────────────────────────── Marketing ───────────────────────────
model Coupon {
  id         String     @id @default(cuid())
  code       String     @unique
  type       CouponType @default(PERCENT)
  value      Float
  minTotal   Float      @default(0)
  expiresAt  DateTime?
  active     Boolean    @default(true)
  usageLimit Int?
  usedCount  Int        @default(0)
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int
  comment   String?  @db.Text
  // Moderação: avaliações só aparecem na loja após aprovação do dono.
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId])
}

// Lista de desejos por conta (sincroniza entre dispositivos do cliente).
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}

// ─────────────────────────── Unidades (Matriz + Filiais) ───────────────────────────
// Catálogo e preços são compartilhados (globais no Product). O que é por unidade:
// estoque (Inventory), pedidos (Order.pharmacyId) e escopo do admin (User.pharmacyId).
model Pharmacy {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  type      PharmacyType @default(FILIAL)
  active    Boolean      @default(true)
  zip       String?
  street    String?
  number    String?
  district  String?
  city      String?
  state     String?
  phone     String?
  whatsapp  String?
  hours     String?
  // Frete por unidade: override do frete global (Setting). null = usa o global.
  shippingFlat    Float?
  shippingFreeMin Float?
  // Dados regulatórios (ANVISA) por unidade: override do global. null = global.
  cnpj           String?
  pharmacistName String?
  pharmacistCrf  String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  inventory Inventory[]
  cepRanges PharmacyCepRange[]
  orders    Order[]
  users     User[]
  carts     Cart[]

  @@index([type])
}

// Faixas de CEP atendidas por uma unidade (numéricas, 8 dígitos). O roteamento
// escolhe a primeira unidade cuja faixa contém o CEP; sem casar, cai na matriz.
model PharmacyCepRange {
  id         String @id @default(cuid())
  pharmacyId String
  start      Int
  end        Int

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@index([pharmacyId])
}

// Estoque de um produto numa unidade. Fonte da verdade do estoque (substitui
// Product.stock/minStock, mantidos como legado até a migração de limpeza).
model Inventory {
  id         String @id @default(cuid())
  productId  String
  pharmacyId String
  stock      Int    @default(0)
  minStock   Int    @default(5)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@unique([productId, pharmacyId])
  @@index([pharmacyId])
  @@index([productId])
}

// ─────────────────────────── Assinaturas ───────────────────────────
// Reposição recorrente de uso contínuo (sem cobrança automática): no vencimento
// o cron lembra o cliente por e-mail e o "Repor agora" leva à sacola em 1 clique.
// Produtos com receita ficam de fora (exigem validação farmacêutica a cada compra).
model Subscription {
  id             String             @id @default(cuid())
  userId         String
  productId      String
  qty            Int                @default(1)
  intervalDays   Int                @default(30)
  status         SubscriptionStatus @default(ACTIVE)
  nextDueAt      DateTime
  lastNotifiedAt DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([status, nextDueAt])
}

// Trilha de auditoria das ações do admin. userEmail é um snapshot (sobrevive à
// exclusão/anonimização do usuário). Best-effort: gravado fora do caminho crítico.
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userEmail  String?
  action     String
  entity     String?
  entityId   String?
  detail     String?  @db.Text
  pharmacyId String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action])
}

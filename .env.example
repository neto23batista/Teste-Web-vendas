APP_NAME=FarmaVida
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=America/Sao_Paulo
APP_KEY=change-me-use-a-32-byte-random-secret

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=farmavida
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

SESSION_SECURE=false
SESSION_NAME=farmavida_session
TRUSTED_PROXIES=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=nao-responda@farmavida.local
SMTP_FROM_NAME=FarmaVida

MERCADO_PAGO_MODE=sandbox
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_NOTIFICATION_URL=

UPLOAD_MAX_MB=8
LOG_RETENTION_DAYS=90

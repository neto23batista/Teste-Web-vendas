# Copie para .env e ajuste. NUNCA comite o .env real.

# Banco: PostgreSQL (Neon). Na Vercel, as duas variáveis abaixo são criadas
# automaticamente pela integração Storage → Neon. Localmente, copie do painel
# do Neon (console.neon.tech).
#  - DATABASE_URL: conexão "pooled" (com -pooler no host) — usada pela app.
#  - DATABASE_URL_UNPOOLED: conexão direta — usada pelo Prisma nas migrations.
DATABASE_URL="postgresql://USUARIO:SENHA@ep-xxxx-pooler.REGIAO.aws.neon.tech/NOME?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USUARIO:SENHA@ep-xxxx.REGIAO.aws.neon.tech/NOME?sslmode=require"

# Auth.js — gere com: npx auth secret
AUTH_SECRET="troque-por-um-segredo-aleatorio"
AUTH_TRUST_HOST="true"
# Opcional: fixa a URL pública do Auth.js (recomendado em produção/Vercel).
# Em http (sem TLS) defina http://... para desativar cookies "secure".
# AUTH_URL="https://seudominio.com.br"

# App — em produção use https:// (cookies seguros dependem disso)
NEXT_PUBLIC_APP_NAME="FarmaVida"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# PagBank (token de API do painel PagBank > Integrações; pagamento real)
PAGBANK_TOKEN=""
# Use "1" para apontar para o sandbox do PagBank (testes sem dinheiro real)
PAGBANK_SANDBOX=""

# Dados regulatórios da farmácia (exibidos no rodapé — exigência ANVISA).
NEXT_PUBLIC_PHARMACIST_NAME=""
NEXT_PUBLIC_PHARMACIST_CRF=""
NEXT_PUBLIC_CNPJ=""

# Uploads privados (receitas).
# - Local (default): salva em UPLOAD_DIR ou ./private-uploads. Bom p/ VPS/Docker
#   com volume persistente. NÃO funciona em serverless (FS efêmero).
# - S3/compatível (R2, MinIO, Spaces): defina STORAGE_DRIVER=s3 + as S3_*.
UPLOAD_DIR=""
STORAGE_DRIVER=""           # "local" (default) ou "s3"
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""              # opcional (R2/MinIO/Spaces). Vazio = AWS S3.
S3_PREFIX=""               # opcional, prefixo das chaves (ex.: "farmavida/")

# E-mail transacional (Resend). Sem isso, os e-mails só são logados no console
# (dev). Em produção, defina os dois para enviar de verdade.
# MAIL_FROM precisa ser de um domínio verificado no Resend.
RESEND_API_KEY=""
MAIL_FROM="FarmaVida <nao-responda@seudominio.com.br>"

# Rate-limit durável (Upstash Redis, plano free: console.upstash.com).
# Sem as duas, o limite de tentativas (login/checkout/busca) é POR INSTÂNCIA —
# fraco na Vercel. Copie a REST URL e o token do painel do banco Redis.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Segredo do cron de assinaturas (/api/cron/subscriptions). Na Vercel, defina a
# env CRON_SECRET (Settings → Environment Variables) — o agendador dela envia
# "Authorization: Bearer <CRON_SECRET>" automaticamente. Gere um valor aleatório.
CRON_SECRET=""

# Monitoramento (Sentry) — opcional. Sem DSN, fica desligado.
# SENTRY_DSN: erros de servidor; NEXT_PUBLIC_SENTRY_DSN: erros no navegador.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0"
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0"
